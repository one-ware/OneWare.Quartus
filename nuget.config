<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Local build of OneWare packages (development — points to locally packed nupkg).
         Remove or update this entry once the new package is published to nuget.org. -->
    <add key="local-oneware" value="/tmp/local-nuget" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>

